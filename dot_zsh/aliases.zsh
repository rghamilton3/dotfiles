# Set aria2 as file downloader
alias get='aria2c --max-connection-per-server=5 --continue'
# Resource usage
alias df='df -h'
alias du='du -h'
# Safe ch operations
alias chmod='chmod --preserve-root -v'
alias chown='chown --preserve-root -v'
# Replace `ls` with `eza`
alias ls='e'
alias ll='ell'
# Replace `cat`
alias cat="bat"
# Use neovim
alias vim="nvim"
