{
  "vitest-imports": {
    "prefix": "vt-imp",
    "body": ["import { describe, it, expect$0 } from 'vitest'"],
    "description": "Import describe, it, expect"
  },
  "vitest-describe": {
    "prefix": "vt-desc",
    "body": [
      "describe($1, () => {",
      "    $2",
      "    it($3, () => {",
      "        $4",
      "        expect($5)$0",
      "    })",
      "})"
    ],
    "description": "Vitest describe block"
  },
  "vitest-it": {
    "prefix": "vt-it",
    "body": [
      "    it($2, () => {",
      "        $3",
      "        expect($4)$0",
      "    })"
    ],
    "description": "Vitest it block"
  }
}
